import { ScrollView, TextEdit } from "std-widgets.slint";

component PopupItem inherits Rectangle {
    in property <string> item_text;
    in property <string> shortcut;
    callback item_clicked;

    min-height: 28px;
    min-width: 180px;
    background: white;
    border-radius: 2px;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 20px;
        Text { text: item_text; font-size: 13px; color: #333; horizontal-stretch: 1; vertical-alignment: center; }
        Text { text: shortcut; font-size: 11px; color: #999; vertical-alignment: center; }
    }

    TouchArea { width: 100%; height: 100%; clicked => { item_clicked(); } }
}

export component GCodeEditor inherits Window {
    title: "G-Code Editor";
    preferred-width: 1000px;
    preferred-height: 750px;
    min-width: 600px;
    min-height: 400px;

    in-out property <string> file_path;
    in-out property <string> code_content;
    in-out property <string> status_text;
    in-out property <bool> edit_mode: false;

    in-out property <bool> file_menu_open;
    in-out property <bool> edit_menu_open;
    in-out property <bool> help_menu_open;

    callback menu_file_toggle();
    callback menu_edit_toggle();
    callback menu_help_toggle();
    callback close_menus();

    callback menu_file_open();
    callback menu_file_save();
    callback menu_file_save_as();
    callback menu_file_close();
    callback menu_file_exit();
    callback menu_edit_format();
    callback menu_edit_validate();
    callback menu_edit_toggle_mode();
    callback menu_help_about();
    callback menu_help_shortcuts();

    VerticalLayout {

        Rectangle {
            background: #f5f5f5;
            min-height: 30px;

            HorizontalLayout {
                spacing: 0;
                padding-left: 4px;

                Rectangle {
                    width: 60px; min-height: 28px;
                    background: #e8e8e8; border-radius: 3px;
                    Text { text: "File"; font-size: 13px; color: #333; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: 100%; height: 100%; clicked => { menu_file_toggle(); } }
                }
                Rectangle {
                    width: 60px; min-height: 28px;
                    background: #e8e8e8; border-radius: 3px;
                    Text { text: "Edit"; font-size: 13px; color: #333; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: 100%; height: 100%; clicked => { menu_edit_toggle(); } }
                }
                Rectangle {
                    width: 60px; min-height: 28px;
                    background: #e8e8e8; border-radius: 3px;
                    Text { text: "Help"; font-size: 13px; color: #333; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: 100%; height: 100%; clicked => { menu_help_toggle(); } }
                }

                HorizontalLayout { horizontal-stretch: 1; }
                Text { text: file_path; color: #999; font-size: 12px; vertical-alignment: center; }
            }
        }

        sa := TextEdit {
                //text: root.code_content;
                //edited(str) <=> { root.code_content = str; }
                text <=> root.code_content;
                font-family: "Consolas";
                font-size: 13px;
                read-only: false;
                horizontal-stretch: 1;
                vertical-stretch: 1;
        }

        Rectangle {
            background: #2c3e50; min-height: 28px;
            HorizontalLayout {
                padding-top: 4px; padding-bottom: 4px; padding-left: 8px; padding-right: 8px;
                Text { text: status_text; font-size: 12px; color: #ecf0f1; horizontal-stretch: 1; vertical-alignment: center; }
                Text { text: "v0.1"; font-size: 11px; color: #95a5a6; vertical-alignment: center; }
            }
        }

    }

    if (file_menu_open) : Rectangle {
                border-radius: 4px; width: 200px; x: 4px; y: 30px;
                VerticalLayout {
                    spacing: 0; padding: 4px;
                    PopupItem { item_text: "Open...";      shortcut: "Ctrl+O"; item_clicked => { file_menu_open = false; menu_file_open(); } }
                    PopupItem { item_text: "Save";         shortcut: "Ctrl+S"; item_clicked => { file_menu_open = false; menu_file_save(); } }
                    PopupItem { item_text: "Save as...";   shortcut: "";       item_clicked => { file_menu_open = false; menu_file_save_as(); } }
                    PopupItem { item_text: "Close";        shortcut: "";       item_clicked => { file_menu_open = false; menu_file_close(); } }
                    Rectangle { min-height: 1px; max-height: 1px; background: #ddd; }
                    PopupItem { item_text: "Exit";         shortcut: "Ctrl+Q"; item_clicked => { file_menu_open = false; menu_file_exit(); } }
                }
            }

            if (edit_menu_open) : Rectangle {
                border-radius: 4px; width: 180px; x: 68px; y: 30px;
                VerticalLayout {
                    spacing: 0; padding: 4px;
                    PopupItem { item_text: "Format";       shortcut: "F5"; item_clicked => { edit_menu_open = false; menu_edit_format(); } }
                    PopupItem { item_text: "Validate";     shortcut: "F6"; item_clicked => { edit_menu_open = false; menu_edit_validate(); } }
                }
            }

            if (help_menu_open) : Rectangle {
                border-radius: 4px; width: 150px; x: 132px; y: 30px;
                VerticalLayout {
                    spacing: 0; padding: 4px;
                    PopupItem { item_text: "Shortcuts";    shortcut: "F1";  item_clicked => { help_menu_open = false; menu_help_shortcuts(); } }
                    Rectangle { min-height: 1px; max-height: 1px; background: #ddd; }
                    PopupItem { item_text: "About";        shortcut: "";    item_clicked => { help_menu_open = false; menu_help_about(); } }
                }
            }
}
